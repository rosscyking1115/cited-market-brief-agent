# --- Database ---
DATABASE_URL=postgresql+psycopg://cited_market_brief_agent:cited_market_brief_agent@localhost:5432/cited_market_brief_agent

# --- Cache / queue (Valkey) ---
VALKEY_URL=redis://localhost:6379/0

# --- Object storage (MinIO local / S3 prod) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=cited_market_brief_agent
S3_SECRET_KEY=cited-market-brief-agent-dev-only
S3_BUCKET_RAW=cited-market-brief-agent-raw-sources

# --- SEC EDGAR (REQUIRED: declared UA per fair-access policy, max 10 req/s) ---
# Format: "Company/App Name contact@example.com"
SEC_USER_AGENT=

# --- FRED ---
FRED_API_KEY=

# --- GDELT news discovery (not readership data) ---
# Powers the morning-radar news rail (trending/most-covered discovery). Safe to
# enable: open web discovery, labeled as coverage — never as readership.
GDELT_ENABLED=true
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc
GDELT_REQUEST_TIMEOUT_SECONDS=8

# --- BBC latest-headline RSS (not readership data) ---
# Powers the morning-radar news rail (latest headlines). Safe to enable: public
# RSS, labeled as "latest" — never as "most read".
BBC_RSS_ENABLED=true
BBC_RSS_URL=https://feeds.bbci.co.uk/news/business/rss.xml
BBC_REQUEST_TIMEOUT_SECONDS=8

# --- NYT Most Popular (genuine most-read; free key from developer.nytimes.com) ---
# Powers the honest "最多瀏覽 / Most read" tab. Headlines + links only; links back
# to nytimes.com per NYT developer terms. Window is daily (period 1/7/30).
NYT_ENABLED=false
NYT_API_KEY=
NYT_BASE_URL=https://api.nytimes.com/svc/mostpopular/v2
NYT_REQUEST_TIMEOUT_SECONDS=8
NYT_MOST_POPULAR_PERIOD_DAYS=1

# --- Alpha Vantage pilot market data (FX, WTI, US10Y; enable only after terms review) ---
ALPHA_VANTAGE_ENABLED=false
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
ALPHA_VANTAGE_REQUEST_TIMEOUT_SECONDS=8
ALPHA_VANTAGE_CACHE_TTL_SECONDS=900
ALPHA_VANTAGE_CACHE_MAX_AGE_SECONDS=43200
ALPHA_VANTAGE_MAX_REFRESHES_PER_REQUEST=2
ALPHA_VANTAGE_FAILURE_COOLDOWN_SECONDS=600

# --- LLM providers (library-mode LiteLLM; two providers only at MVP) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GENERATION_MODEL=anthropic/claude-sonnet-4-6
TRANSLATION_MODEL=openai/gpt-4o-mini
TRANSLATION_REQUEST_TIMEOUT_SECONDS=45

# --- AuthN (Phase 5; REQUIRED true in any multi-tenant/production deployment) ---
AUTH_REQUIRED=false
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=120

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO
