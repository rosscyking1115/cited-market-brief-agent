# --- Database ---
DATABASE_URL=postgresql+psycopg://ledgerbrief:ledgerbrief@localhost:5432/ledgerbrief

# --- Cache / queue (Valkey) ---
VALKEY_URL=redis://localhost:6379/0

# --- Object storage (MinIO local / S3 prod) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=ledgerbrief
S3_SECRET_KEY=ledgerbrief-dev-only
S3_BUCKET_RAW=ledgerbrief-raw-sources

# --- SEC EDGAR (REQUIRED: declared UA per fair-access policy, max 10 req/s) ---
# Format: "Company/App Name contact@example.com"
SEC_USER_AGENT=

# --- FRED ---
FRED_API_KEY=

# --- LLM providers (library-mode LiteLLM; two providers only at MVP) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO
