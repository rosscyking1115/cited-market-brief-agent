# Copy to .env.staging on the server. Never commit .env.staging.

# Public staging host, for example:
# STAGING_DOMAIN=staging.yourdomain.com
STAGING_DOMAIN=

# Temporary family-pilot gate handled by Caddy.
# Generate BASIC_AUTH_HASH on the server with:
#   docker run --rm caddy:2.10-alpine caddy hash-password --plaintext "choose-a-password"
BASIC_AUTH_USER=pilot
BASIC_AUTH_HASH=

# Database inside the staging Docker network.
POSTGRES_USER=cited_market_brief_agent
POSTGRES_PASSWORD=
POSTGRES_DB=cited_market_brief_agent

# SEC EDGAR fair-access User-Agent. Format:
#   Cited Market Brief Agent staging you@example.com
SEC_USER_AGENT=

# Data/model providers.
FRED_API_KEY=
GDELT_ENABLED=false
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc
GDELT_REQUEST_TIMEOUT_SECONDS=8
BBC_RSS_ENABLED=false
BBC_RSS_URL=https://feeds.bbci.co.uk/news/rss.xml
BBC_REQUEST_TIMEOUT_SECONDS=8
ALPHA_VANTAGE_ENABLED=false
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
ALPHA_VANTAGE_REQUEST_TIMEOUT_SECONDS=8
ALPHA_VANTAGE_CACHE_TTL_SECONDS=900
ALPHA_VANTAGE_CACHE_MAX_AGE_SECONDS=43200
ALPHA_VANTAGE_MAX_REFRESHES_PER_REQUEST=2
ALPHA_VANTAGE_FAILURE_COOLDOWN_SECONDS=600
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GENERATION_MODEL=anthropic/claude-sonnet-4-6
TRANSLATION_MODEL=openai/gpt-4o-mini

# Staging defaults.
ENVIRONMENT=production
AUTH_REQUIRED=false
RATE_LIMIT_PER_MINUTE=120
LOG_LEVEL=INFO
TRANSLATION_REQUEST_TIMEOUT_SECONDS=45

# Future OIDC auth. Keep empty while Caddy basic auth gates the family pilot.
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
